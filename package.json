{
    "name": "backforge-be",
    "version": "1.0.0",
    "description": "BackForge Backend API with PostgreSQL",
    "main": "src/server.js",
    "scripts": {
        "start": "NODE_ENV=production node src/server.js",
        "dev": "NODE_ENV=development nodemon src/server.js",
        "prod": "NODE_ENV=production node src/server.js",
        "dev:start": "NODE_ENV=development node src/server.js",
        "prod:start": "NODE_ENV=production node src/server.js",
        "db:migrate": "node src/database/migrate.js",
        "db:migrate:dev": "NODE_ENV=development node src/database/migrate.js",
        "db:migrate:prod": "NODE_ENV=production node src/database/migrate.js",
        "db:seed": "node src/database/seed.js",
        "db:seed:dev": "NODE_ENV=development node src/database/seed.js",
        "db:seed:prod": "NODE_ENV=production node src/database/seed.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "env:dev": "./scripts/switch-env.sh development",
        "env:prod": "./scripts/switch-env.sh production"
    },
    "keywords": [
        "nodejs",
        "postgresql",
        "api",
        "backend"
    ],
    "author": "BackForge Team",
    "license": "MIT",
    "dependencies": {
        "aws-sdk": "^2.1692.0",
        "bcrypt": "^6.0.0",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "express-validator": "^7.0.1",
        "fs-extra": "^11.1.1",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "multer": "^2.0.2",
        "pg": "^8.11.3",
        "socket.io": "^4.8.1",
        "uuid": "^11.1.0"
    },
    "devDependencies": {
        "eslint": "^8.55.0",
        "eslint-config-standard": "^17.1.0",
        "eslint-plugin-import": "^2.29.0",
        "eslint-plugin-n": "^16.3.1",
        "eslint-plugin-promise": "^6.1.1",
        "jest": "^29.7.0",
        "nodemon": "^3.0.2",
        "supertest": "^6.3.3"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}